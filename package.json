{
  "name": "claude-code-evolution-engine",
  "version": "0.1.0",
  "description": "A self-contained research-and-upgrade pipeline that keeps a Claude Code VPS installation at the cutting edge.",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc && cp src/server/public/app.js src/server/public/index.html src/server/public/styles.css dist/server/public/",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "ccee:run": "tsx src/index.ts --run",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "retest": "tsx scripts/retest-proposals.ts"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "node-cron": "^3.0.3"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": ">=2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.14",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
