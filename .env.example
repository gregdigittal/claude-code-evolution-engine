# ============================================================
# Claude Code Evolution Engine — Environment Configuration
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ---- Required -----------------------------------------------

# Anthropic API key — used for Claude Code SDK authentication
ANTHROPIC_API_KEY=

# GitHub personal access token (read:repo, public_repo scopes)
GITHUB_TOKEN=

# ---- Optional (have sensible defaults) ----------------------

# Path to the Obsidian staging directory on the VPS
OBSIDIAN_STAGING_PATH=/home/gregmorris/ccee-obsidian-staging

# Git remote for the Obsidian vault (used for auto-push after doc generation)
OBSIDIAN_VAULT_GIT_REMOTE=

# Port for the CCEE Review UI (Express server)
REVIEW_UI_PORT=9898

# Port for the health check endpoint
HEALTH_PORT=3000

# Tailscale IP — used so the review UI advertises the correct external address
VPS_TAILSCALE_IP=100.88.238.20

# Slack webhook URL for notifications (pipeline start/complete/error)
SLACK_WEBHOOK_URL=

# Directory for runtime data (store, latest run pointer)
DATA_DIR=./data

# Directories for CCEE runtime state
CCEE_RUN_DIR=/home/gregmorris/.ccee/runs
CCEE_BACKUP_DIR=/home/gregmorris/.ccee/backups
CCEE_CACHE_DIR=/home/gregmorris/.ccee/repo-cache
CCEE_TEST_ENV_DIR=/home/gregmorris/.ccee/test-env
