# Claude Code Evolution Engine — Environment Configuration
# Copy this file to .env and fill in the required values.
# Never commit .env to git.

# ---------------------------------------------------------------------------
# Required — pipeline will not start without these
# ---------------------------------------------------------------------------

# Anthropic API key for Claude (used by content generation phases)
ANTHROPIC_API_KEY=

# GitHub personal access token — fine-grained, public repos read-only
# Required for rate-limit headroom during the research sweep (5000 req/hr vs 60)
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Optional — sensible defaults are used if not set
# ---------------------------------------------------------------------------

# Path where CCEE writes Obsidian-ready markdown and SVGs before Git sync
OBSIDIAN_STAGING_PATH=/home/gregmorris/ccee-obsidian-staging

# Git remote for pushing Obsidian docs (e.g. git@github.com:you/vault.git)
OBSIDIAN_VAULT_GIT_REMOTE=

# Port for the review UI Express server
REVIEW_UI_PORT=9898

# Port for the lightweight health check endpoint
HEALTH_PORT=3000

# Tailscale IP of this VPS
VPS_TAILSCALE_IP=100.88.238.20

# Slack webhook URL for run completion notifications (optional)
SLACK_WEBHOOK_URL=

# Runtime directories
CCEE_RUN_DIR=/home/gregmorris/.ccee/runs
CCEE_BACKUP_DIR=/home/gregmorris/.ccee/backups
CCEE_CACHE_DIR=/home/gregmorris/.ccee/repo-cache
CCEE_TEST_ENV_DIR=/home/gregmorris/.ccee/test-env

# Data directory
DATA_DIR=./data
